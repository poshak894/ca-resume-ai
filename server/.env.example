# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ca-resume-ai?retryWrites=true&w=majority

# Auth and session
JWT_SECRET=replace_with_a_long_random_jwt_secret
SESSION_SECRET=replace_with_a_long_random_session_secret
ADMIN_PASS=replace_with_admin_password
SKIP_EMAIL_VERIFICATION=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# AI providers
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
MERCHANT_ID=your_merchant_id
